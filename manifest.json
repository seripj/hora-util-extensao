{
  "manifest_version": 3,
  "name": "HoraÚtil — Calculadora de Dias",
  "version": "1.0.0",
  "description": "Calcula dias úteis, horas a baixar e saldo de horas por mês ou período.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HoraÚtil"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
